# Copy this file to .env.local or .env.e2e.local when a Firebase test project exists.
# These values are public Firebase Web SDK config values, but they should still
# point to a dedicated test project so E2E data never writes to production.

VITE_E2E_FIREBASE_API_KEY=
VITE_E2E_FIREBASE_AUTH_DOMAIN=
VITE_E2E_FIREBASE_PROJECT_ID=
VITE_E2E_FIREBASE_STORAGE_BUCKET=
VITE_E2E_FIREBASE_MESSAGING_SENDER_ID=
VITE_E2E_FIREBASE_APP_ID=
