rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isFileOwner(userId) {
      return isSelf(userId);
    }

    function isFileEditor() {
      return isSignedIn() &&
        (
          (
            resource.data.editorUids is list &&
            request.auth.uid in resource.data.editorUids
          ) ||
          (
            request.resource.data.editorUids is list &&
            request.auth.uid in request.resource.data.editorUids
          )
        );
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSelf(userId);
      allow update: if isSelf(userId);
      allow delete: if false;

      match /friends/{friendId} {
        allow read: if isSelf(userId) || isSelf(friendId);
        allow create: if
          isSelf(userId) ||
          (
            isSelf(friendId) &&
            request.resource.data.friendUid == friendId
          );
        allow delete: if
          isSelf(userId) ||
          (
            isSelf(friendId) &&
            resource.data.friendUid == friendId
          );
        allow update: if isSelf(userId);
      }

      match /files/{fileId} {
        allow read: if isFileOwner(userId) || isFileEditor();
        allow create: if isFileOwner(userId);
        allow update: if isFileOwner(userId) || isFileEditor();
        allow delete: if false;
      }

      match /sharedFiles/{sharedFileId} {
        allow read: if isSelf(userId);
        allow create, update: if
          isSelf(userId) ||
          (
            isSignedIn() &&
            request.resource.data.ownerUid == request.auth.uid
          );
        allow delete: if false;
      }

      match /settings/{settingId} {
        allow read, create, update: if isSelf(userId);
        allow delete: if false;
      }

      match /diagnosticReports/{reportId} {
        allow read: if isSelf(userId);
        allow create: if
          isSelf(userId) &&
          request.resource.data.reportId == reportId &&
          request.resource.data.reporterUid == userId &&
          request.resource.data.status == "reported";
        allow update, delete: if false;
      }
    }

    match /friendRequests/{requestId} {
      allow get: if isSignedIn();

      allow list: if
        isSignedIn() &&
        (
          request.auth.uid == resource.data.fromUid ||
          request.auth.uid == resource.data.toUid
        );

      allow create: if
        isSignedIn() &&
        request.auth.uid == request.resource.data.fromUid &&
        request.resource.data.status == "pending" &&
        request.resource.data.fromUid != request.resource.data.toUid;

      allow update: if
        isSignedIn() &&
        (
          (
            request.auth.uid == resource.data.toUid &&
            resource.data.status == "pending" &&
            (
              request.resource.data.status == "accepted" ||
              request.resource.data.status == "rejected"
            )
          ) ||
          (
            request.auth.uid == resource.data.fromUid &&
            resource.data.status == "pending" &&
            request.resource.data.status == "cancelled"
          )
        );

      allow delete: if false;
    }

    match /friendInvites/{inviteId} {
      allow read: if true;

      allow create: if
        isSignedIn() &&
        request.auth.uid == request.resource.data.issuedByUid &&
        request.resource.data.status == "active";

      allow update: if
        isSignedIn() &&
        request.auth.uid == resource.data.issuedByUid &&
        request.auth.uid == request.resource.data.issuedByUid;

      allow delete: if false;
    }

    match /systemLogs/{logId} {
      allow read: if isSignedIn();
      allow create: if
        isSignedIn() &&
        (
          request.resource.data.phase == "started" ||
          request.resource.data.phase == "completed" ||
          request.resource.data.phase == "failed"
        );
      allow update, delete: if false;
    }

    match /diagnosticReports/{reportId} {
      allow create: if
        (
          isSignedIn() &&
          request.resource.data.reporterUid == request.auth.uid &&
          request.resource.data.status == "reported"
        ) ||
        (
          !isSignedIn() &&
          request.resource.data.reporterUid == null &&
          request.resource.data.status == "reported"
        );
      allow read: if
        isSignedIn() &&
        resource.data.reporterUid == request.auth.uid;
      allow update, delete: if false;
    }

    match /diagnosticReportStatuses/{reportId} {
      allow get: if true;
      allow list: if false;
      allow create: if
        request.resource.data.reportId == reportId &&
        request.resource.data.status == "reported" &&
        (
          (
            isSignedIn() &&
            request.resource.data.reporterUid == request.auth.uid
          ) ||
          (
            !isSignedIn() &&
            request.resource.data.reporterUid == null
          )
        );
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
